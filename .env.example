# =============================================================================
# Env var template — safe to commit. Copy to .env.local and fill real values.
# =============================================================================

# IndexNow — Bing/Yandex/Naver/Seznam/Copilot instant indexing
# - Generate any hex string 8-128 chars long, e.g.:
#     python3 -c "import secrets; print(secrets.token_hex(16))"
# - Host the key at /public/<KEY>.txt with the key as plain-text content
#   so https://hamitahm.com/<KEY>.txt serves it back.
INDEXNOW_KEY=

# Required to authenticate POST /api/indexnow. Pick anything sufficiently long.
# Generate with:
#     python3 -c "import secrets; print(secrets.token_hex(32))"
INDEXNOW_SECRET=
